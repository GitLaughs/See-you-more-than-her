config BR2_PACKAGE_SSNE_AI_DEMO
	bool "ssne_ai_demo (人脸检测+底盘控制+OSD标签)"
	select BR2_PACKAGE_SSNE
	help
	  SmartSens A1 AI demo application.
	  Features: SCRFD face detection, OSD visualization with labels,
	  STM32 AKM chassis UART control, RPLidar integration.

config BR2_M1_AI_DEMO_SDK_ROOT_PATH
	string "SDK lib root path (for AI demo)"
	default "opt/m1_sdk/usr"
	help
	  Path relative to BASE_DIR (output/) where SSNE SDK headers (/include)
	  and libs (/lib) are located.
