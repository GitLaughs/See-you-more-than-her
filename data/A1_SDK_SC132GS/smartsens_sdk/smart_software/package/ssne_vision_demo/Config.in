config BR2_PACKAGE_SSNE_VISION_DEMO
	bool "ssne_vision_demo (YOLOv8+OSD+Lidar+Debug)"
	select BR2_PACKAGE_SSNE
	help
	  SmartSens integrated vision demo with YOLOv8 object detection,
	  multi-layer OSD overlay, RPLidar obstacle avoidance, and
	  Aurora TCP debug interface (port 9090).

config BR2_M1_VISION_SDK_ROOT_PATH
	string "SDK lib root path (for vision demo)"
	default "opt/m1_sdk/usr"
	help
	  Path relative to BASE_DIR (output/) where SSNE SDK headers (/include)
	  and libs (/lib) are located.

